<!-- app/views/rooms/new.html.erb -->

<div class="rooms-new">
  <h1>Создать новую чат-комнату</h1>

  <%= form_with(model: @room, local: true) do |f| %>
    <% if @room.errors.any? %>
      <div class="error-message">
        <%= @room.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :name, "Название комнаты (уникальное)" %><br>
      <%= f.text_field :name, placeholder: "Например: ruby-news", autocomplete: "off" %>
    </div>

    <div class="actions">
      <%= f.submit "Создать комнату" %>
    </div>
  <% end %>

  <%= link_to "Назад к списку", rooms_path, class: "back-link" %>
</div>
